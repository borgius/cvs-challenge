# Keep `.env` focused on app runtime values and the small set of deployment
# secrets that still become Lambda environment variables. Put non-secret
# OpenTofu root variables in `infra/terraform/env/*.auto.tfvars` instead.

# App runtime and deployment secrets
# GITHUB_WEBHOOK_SECRET is reused by scripts/configure-self-webhook.sh when you
# explicitly configure this repository's managed pull_request webhook.
# Live GitHub check publication now uses GitHub App installation auth.
# Keep GITHUB_TOKEN empty unless you want an extra fallback for changed-file
# lookups. Do not reuse any runtime credential as the repository-admin token
# for webhook management.
GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_APP_ID=replace-me
# Keep the private key on one line with escaped newlines when you source this
# file locally, for example:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=replace-me-as-single-line-pem
# Optional. Leave blank to let the app resolve the repository installation ID.
GITHUB_APP_INSTALLATION_ID=
# Optional fallback for changed-file lookups when you do not want to rely on
# the GitHub App token for that read path.
GITHUB_TOKEN=
AWS_REGION=us-east-1
EVALUATIONS_TABLE_NAME=pr-concierge-evaluations
RAW_EVENT_BUCKET_NAME=
ENABLE_RAW_EVENT_ARCHIVE=false
REQUIRED_LABELS=
EVALUATION_REPOSITORY=console

# One-time backend bootstrap inputs used by scripts/bootstrap-tofu-backend.sh
TOFU_STATE_BUCKET=
TOFU_LOCK_TABLE=
TOFU_STATE_REGION=
TOFU_STATE_BUCKET_FORCE_DESTROY=false
TOFU_STATE_BUCKET_VERSIONING_ENABLED=true
TOFU_LOCK_TABLE_POINT_IN_TIME_RECOVERY_ENABLED=false
TOFU_LOCK_TABLE_DELETION_PROTECTION_ENABLED=false

# Optional script selector. Deploy and destroy default to the `dev` files under
# infra/terraform/ unless you set one of these overrides.
# TOFU_ENVIRONMENT=dev
# TOFU_VAR_FILE=/absolute/path/to/custom.auto.tfvars
# TOFU_BACKEND_FILE=/absolute/path/to/custom.s3.tfbackend
